# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
LLM_MODEL=gemini-2.0-flash-lite

# GitHub
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=launchmind-GigGuard

# Slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Email provider: brevo or sendgrid
EMAIL_PROVIDER=brevo

# Brevo (Email)
BREVO_API_KEY=your-brevo-api-key
BREVO_FROM_EMAIL=your-verified-sender@example.com
BREVO_TO_EMAIL=test-recipient@example.com

# SendGrid (Email)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=your-verified-sender@example.com
SENDGRID_TO_EMAIL=test-recipient@example.com
